# =========================================================================
# VAV CENTRAL — variaveis de ambiente
# Copie para .env.local e preencha. NUNCA commitar .env.local.
# =========================================================================

# --- Supabase ---
# Pegue em: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# --- Google OAuth (Drive + Meet) ---
# Crie credenciais OAuth 2.0 em: https://console.cloud.google.com/apis/credentials
# Refresh token: gere em https://developers.google.com/oauthplayground
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# --- Google Service Account (alternativa para Drive sem OAuth interativo) ---
# Crie uma service account em Google Cloud > IAM
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Cole a chave privada com \n como separador de linha
GOOGLE_PRIVATE_KEY=

# --- Google Calendar (reunioes) ---
# ID do calendario compartilhado onde os eventos serao criados
GOOGLE_CALENDAR_ID=
